# ============================================
# CareerPilot — Complete Environment Variables
# ============================================
# Copy this file to .env.local (frontend) and backend/.env (backend)
# Get ALL API keys before deploying to Heroku

# ============================================
# 1. SUPABASE (Database + Auth)
# ============================================
# Sign up: https://supabase.com/dashboard
# Create project → Settings → API
#
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# 2. GOOGLE GEMINI API (AI Functions)
# ============================================
# Sign up: https://aistudio.google.com/apikey
# Click "Create API Key" → Copy key
# Free tier: 60 requests/minute
#
GOOGLE_API_KEY=AIzaSy...your-gemini-api-key

# ============================================
# 3. RESEND (Email Digests)
# ============================================
# Sign up: https://resend.com/signup
# API Keys → Create API Key
# Free tier: 100 emails/day
#
RESEND_API_KEY=re_...your-resend-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# 4. SITE CONFIGURATION
# ============================================
# Frontend URL (update after Heroku deployment)
NEXT_PUBLIC_SITE_URL=https://your-app.herokuapp.com

# Backend API URL (update after Heroku deployment)
NEXT_PUBLIC_AGENT_API_URL=https://your-backend.herokuapp.com
AGENT_API_URL=https://your-backend.herokuapp.com

# ============================================
# 5. OPTIONAL: OAuth Providers (via Supabase)
# ============================================
# These are configured IN Supabase Dashboard, not here.
# But you need to create apps at:
#
# Google OAuth:
#   1. https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID (Web application)
#   3. Add redirect: https://your-project.supabase.co/auth/v1/callback
#   4. Copy Client ID & Secret → Supabase → Auth → Providers → Google
#
# GitHub OAuth:
#   1. https://github.com/settings/developers
#   2. New OAuth App
#   3. Callback: https://your-project.supabase.co/auth/v1/callback
#   4. Copy Client ID & Secret → Supabase → Auth → Providers → GitHub

# ============================================
# 6. OPTIONAL: Enhanced Features
# ============================================

# Pinecone (Vector search for semantic job matching)
# Sign up: https://www.pinecone.io/
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX=careerpilot-jobs

# Upstash Redis (Rate limiting, caching, queues)
# Sign up: https://upstash.com/
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# Sentry (Error tracking)
# Sign up: https://sentry.io/
# SENTRY_DSN=https://...@sentry.io/...

# ============================================
# QUICK START CHECKLIST
# ============================================
# Minimum required for basic functionality:
#
# ☐ NEXT_PUBLIC_SUPABASE_URL
# ☐ NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY  
# ☐ SUPABASE_SERVICE_KEY
# ☐ GOOGLE_API_KEY
#
# For email digests:
# ☐ RESEND_API_KEY
#
# After Heroku deploy:
# ☐ Update NEXT_PUBLIC_SITE_URL
# ☐ Update NEXT_PUBLIC_AGENT_API_URL
# ☐ Update AGENT_API_URL
